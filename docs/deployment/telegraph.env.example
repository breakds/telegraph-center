# Example secret environment file for Telegraph Center.
#
# In production this is a ragenix-generated file referenced by the systemd unit's
# EnvironmentFile= directive. It MUST NOT be committed with real values and MUST
# NOT live in the Nix store. The TOML config only names these variables; the
# values live here.
#
# Format: systemd EnvironmentFile, one KEY=value per line, no surrounding quotes.

# Soniox async Speech-to-Text API key.
SONIOX_API_KEY=replace-with-soniox-api-key

# Argon2id PHC string for the Operator password. Generate with, e.g.:
#   echo -n 'your-password' | argon2 "$(head -c16 /dev/urandom | base64)" -id -e
# (any Argon2id PHC-format hash works; never store the plaintext password).
TELEGRAPH_OPERATOR_PASSWORD_HASH=$argon2id$v=19$m=19456,t=2,p=1$c2FsdHNhbHQ$replace-with-real-hash

# One variable per Webhook Sink secret (HMAC-SHA256 signing key), named by the
# Sink's `secret_env` in the config.
HERMES_JOURNAL_WEBHOOK_SECRET=replace-with-webhook-hmac-secret
